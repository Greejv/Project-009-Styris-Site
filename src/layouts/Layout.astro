---
import '../styles/fonts.css';
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import SEO from '../components/SEO.astro';
import { SITE, type Crumb } from '../data/site';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  breadcrumbs?: Crumb[];
  /** Page-specific Schema.org nodes merged into the site-wide @graph. */
  schema?: Record<string, unknown>[];
}

const props = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <SEO {...props} />
  </head>
  <body>
    <slot />
    <CookieConsent />
  </body>
</html>
