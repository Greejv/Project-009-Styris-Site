---
const features = [
  { title: 'Osobný prístup od prvého telefonátu', text: 'Bavíme sa s vami priamo — žiadne call centrá ani obchodníci.' },
  { title: 'Orientačná cenová ponuka do 48 hodín', text: 'Ozveme sa rýchlo a s konkrétnym návrhom riešenia.' },
  { title: 'Vlastná dielňa, žiadne medzičlánky', text: 'Vyrábame u seba — máme to pod kontrolou od návrhu po montáž.' },
  { title: 'Dlhá životnosť', text: 'Robíme veci tak, aby slúžili roky. Ak sa niečo pokazí našou chybou, opravíme to zdarma.' },
];
---

<section class="quality section-dark" id="quality">
  <div class="container">
    <div class="quality-inner">
      <div class="reveal">
        <p class="label-bold">Prečo práve my</p>
        <h2 class="headline-lg">Nechcete riskovať?</h2>
        <p class="quality-intro">Najčastejšie nás volajú, keď si nie sú istí. Poradíme, navrhneme rozumné riešenie a dodáme výrobok, ktorý bude slúžiť dlhé roky.</p>
        <div class="quality-features">
          {features.map((f) => (
            <div class="quality-feature">
              <div class="check">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div>
                <h3>{f.title}</h3>
                <p>{f.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="quality-stat reveal">
        <span class="stat-number">100%</span>
        <p>vlastná výroba — od návrhu po montáž, bez subdodávateľov</p>
      </div>
    </div>
  </div>
</section>
