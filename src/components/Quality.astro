---
const features = [
  { title: 'Osobný prístup od prvého telefonátu', text: 'Bavíte sa priamo s tými, čo výrobok vyrobia — žiadne call centrá ani obchodníci.' },
  { title: 'Vlastná dielňa, žiadne medzičlánky', text: 'Vyrábame u seba. Od návrhu po montáž máme celý proces pod kontrolou.' },
  { title: 'Materiál na mieru aplikácii', text: 'Oceľ, nerez alebo hliník — vždy podľa toho, kde bude výrobok slúžiť a čo musí zvládnuť.' },
];
---

<section class="quality section-dark" id="quality">
  <div class="container">
    <div class="quality-inner">
      <div class="reveal">
        <p class="label-bold">Prečo my</p>
        <h2 class="headline-lg">Istota od prvého telefonátu</h2>
        <div class="quality-features">
          {features.map((f) => (
            <div class="quality-feature">
              <div class="check">
                <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <div>
                <h4>{f.title}</h4>
                <p>{f.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="quality-stat reveal">
        <span class="stat-number">100%</span>
        <p>vlastná výroba — od návrhu po montáž, bez subdodávateľov</p>
      </div>
    </div>
  </div>
</section>
