---
import { processSteps as steps } from '../data/process';
---

<section class="process section-dark section-tinted" id="process">
  <div class="container">
    <div class="process-header reveal">
      <p class="label-bold">A K O &nbsp; T O &nbsp; P R E B I E H A</p>
      <h2 class="headline-lg">Od nápadu po hotový kus</h2>
      <p class="process-subtitle">Nemusíte mať všetko vymyslené dopredu. Prevedieme vás celým procesom — od prvého telefonátu až po montáž.</p>
      <div class="process-freebie">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        <span>Nedávame papierovú záruku — <strong>staviame veci tak, aby prežili dom</strong>. Ak sa niečo pokazí našou chybou, opravíme to zdarma.</span>
      </div>
    </div>
    <div class="process-grid">
      <div class="process-path" aria-hidden="true">
        <svg viewBox="0 0 1000 60" preserveAspectRatio="none">
          <defs>
            <linearGradient id="pathGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(254,193,44,0)"></stop>
              <stop offset="50%" stop-color="rgba(254,193,44,1)"></stop>
              <stop offset="100%" stop-color="rgba(254,193,44,0)"></stop>
            </linearGradient>
          </defs>
          <path class="path-track" d="M 110 30 Q 240 -5, 370 30 T 630 30 T 890 30"></path>
          <path class="path-glow" d="M 110 30 Q 240 -5, 370 30 T 630 30 T 890 30"></path>
          <circle class="path-node" cx="110" cy="30" r="4"></circle>
          <circle class="path-node" cx="370" cy="30" r="4"></circle>
          <circle class="path-node" cx="630" cy="30" r="4"></circle>
          <circle class="path-node" cx="890" cy="30" r="4"></circle>
        </svg>
      </div>
      {steps.map((s) => (
        <div class="process-card reveal">
          <div class="process-step-num">{s.num}</div>
          <div class="process-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#B8860B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={s.icon}></svg>
          </div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
