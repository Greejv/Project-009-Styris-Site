---
const steps = [
  {
    num: '01',
    title: 'Konzultácia',
    text: 'Spíšeme, čo potrebujete a kde to bude slúžiť. Poradíme rozumné riešenie — aj keď ešte nemáte nič vymyslené.',
    icon: '<path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"></path>',
  },
  {
    num: '02',
    title: 'Návrh a cenová ponuka',
    text: 'Pripravíme návrh riešenia a orientačnú cenu do 48 hodín, aby ste vedeli, s čím počítať.',
    icon: '<path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"></path>',
  },
  {
    num: '03',
    title: '3D vizualizácia a výroba',
    text: 'Po odsúhlasení ceny pripravíme 3D vizualizáciu, aby ste videli finálny kus — a potom ho ručne vyrobíme vo vlastnej dielni.',
    icon: '<circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"></path>',
  },
  {
    num: '04',
    title: 'Doprava a montáž',
    text: 'Privezieme a odborne osadíme priamo u vás, aby ste mali čo najmenej starostí.',
    icon: '<path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"></path>',
  },
];
---

<section class="process section-dark section-tinted" id="process">
  <div class="container">
    <div class="process-header reveal">
      <p class="label-bold">A K O &nbsp; T O &nbsp; P R E B I E H A</p>
      <h2 class="headline-lg">Od nápadu po hotový kus</h2>
      <div class="process-freebie">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
        <span>Nedávame papierovú záruku — <strong>staviame veci tak, aby prežili dom</strong>. Ak sa niečo pokazí našou chybou, opravíme to zdarma.</span>
      </div>
    </div>
    <div class="process-grid">
      <div class="process-path" aria-hidden="true">
        <svg viewBox="0 0 1000 60" preserveAspectRatio="none">
          <defs>
            <linearGradient id="pathGradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="rgba(254,193,44,0)"></stop>
              <stop offset="50%" stop-color="rgba(254,193,44,1)"></stop>
              <stop offset="100%" stop-color="rgba(254,193,44,0)"></stop>
            </linearGradient>
          </defs>
          <path class="path-track" d="M 110 30 Q 240 -5, 370 30 T 630 30 T 890 30"></path>
          <path class="path-glow" d="M 110 30 Q 240 -5, 370 30 T 630 30 T 890 30"></path>
          <circle class="path-node" cx="110" cy="30" r="4"></circle>
          <circle class="path-node" cx="370" cy="30" r="4"></circle>
          <circle class="path-node" cx="630" cy="30" r="4"></circle>
          <circle class="path-node" cx="890" cy="30" r="4"></circle>
        </svg>
      </div>
      {steps.map((s) => (
        <div class="process-card reveal">
          <div class="process-step-num">{s.num}</div>
          <div class="process-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#B8860B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={s.icon}></svg>
          </div>
          <h3>{s.title}</h3>
          <p>{s.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
