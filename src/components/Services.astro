---
import { Image } from 'astro:assets';
import { projects } from '../data/projects';
import { cardImage } from '../data/projectImages';

// The homepage services grid uses the 5 primary categories in the design's bento layout.
const cardOrder = ['kovove-brany-a-ploty', 'schodiska-na-mieru', 'zabradlia-a-madla', 'pergoly-a-zastresenia', 'kovove-doplnky'];
const cardClasses = ['sc-1', 'sc-2', 'sc-3', 'sc-4', 'sc-5'];

const cards = cardOrder.map((slug, i) => {
  const p = projects.find((x) => x.slug === slug)!;
  return { p, cls: cardClasses[i], img: cardImage[slug] };
});
---

<section class="services" id="gallery">
  <div class="container">
    <div class="services-top reveal">
      <div>
        <p class="label-bold">Naše služby</p>
        <h2 class="headline-lg">Vyrábame s vášňou</h2>
        <p>Od brán po pergoly — všetko na mieru, všetko ručne, všetko pre váš dom.</p>
      </div>
      <a href="/prace" class="services-see-all">
        Všetky práce
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
    <div class="services-grid">
      {cards.map(({ p, cls, img }) => (
        <article class={`service-card ${cls} reveal`}>
          <div class="service-img has-photo">
            <Image
              src={img.src}
              alt={img.alt}
              width={900}
              height={Math.round((900 * img.src.height) / img.src.width)}
              widths={[400, 640, 900]}
              sizes="(max-width: 900px) 100vw, 45vw"
              loading="lazy"
            />
          </div>
          <div class="service-content">
            <div class="service-icon-sm">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={p.icon}></svg>
            </div>
            <h3>{p.title}</h3>
            <p>{p.short}</p>
            <a href={`/prace/${p.slug}`} class="service-cta">
              Zobraziť projekt
              <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
