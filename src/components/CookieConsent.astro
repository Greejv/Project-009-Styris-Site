---
/* Cookie consent banner — loads GA, Meta Pixel & Vercel Analytics only after acceptance */
---

<div id="cookie-consent" class="cookie-banner" role="dialog" aria-label="Súhlas s cookies" hidden>
  <div class="cookie-icon" aria-hidden="true">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <circle cx="8" cy="9" r="1.2" fill="currentColor" stroke="none"/>
      <circle cx="14" cy="7.5" r="1" fill="currentColor" stroke="none"/>
      <circle cx="16" cy="13" r="1.2" fill="currentColor" stroke="none"/>
      <circle cx="10" cy="15" r="1" fill="currentColor" stroke="none"/>
      <circle cx="6.5" cy="13" r="0.8" fill="currentColor" stroke="none"/>
    </svg>
  </div>
  <div class="cookie-content">
    <p class="cookie-title">Súbory cookies</p>
    <p class="cookie-text">
      Používame cookies na analýzu návštevnosti a&nbsp;vyhodnotenie reklamy. Váš súhlas môžete kedykoľvek zmeniť.
      <a href="/ochrana-sukromia">Viac informácií</a>
    </p>
  </div>
  <div class="cookie-actions">
    <button id="cookie-decline" class="cookie-btn cookie-btn--decline" type="button">Odmietnuť</button>
    <button id="cookie-accept" class="cookie-btn cookie-btn--accept" type="button">Súhlasím</button>
  </div>
</div>

<script>
  declare global {
    interface Window {
      dataLayer: any[];
      gtag: (...args: any[]) => void;
      fbq: any;
      _fbq: any;
    }
  }

  /* ─── Google Consent Mode v2 ───
   * 1. Set consent defaults BEFORE gtag loads (denied by default)
   * 2. Load the Google tag (it respects consent state automatically)
   * 3. On user accept: call gtag('consent','update',...) on the SAME page
   * 4. On subsequent pages: restore consent state from localStorage before tags fire
   */

  let gaLoaded = false;
  let metaPixelLoaded = false;
  let eventsbound = false;

  // ── Step 1: gtag function + consent defaults (runs immediately, before GA loads) ──
  window.dataLayer = window.dataLayer || [];
  // Must push the `arguments` object (not a plain array) — gtag.js only treats
  // arguments-objects in dataLayer as commands; arrays are silently ignored.
  function gtag() { window.dataLayer.push(arguments); }
  window.gtag = gtag;

  // Read stored consent to set correct defaults on page load
  const storedConsent = localStorage.getItem('cookie-consent');
  const consentState = storedConsent === 'accepted' ? 'granted' : 'denied';

  // Consent Mode v2: set default consent BEFORE loading the Google tag
  gtag('consent', 'default', {
    'ad_storage': consentState,
    'ad_user_data': consentState,
    'ad_personalization': consentState,
    'analytics_storage': consentState,
    'wait_for_update': 500,
  });

  // Redact ad data when consent is denied
  gtag('set', 'ads_data_redaction', true);
  // Enable URL passthrough for better measurement without cookies
  gtag('set', 'url_passthrough', true);

  // ── Step 2: Load Google Analytics (always, consent mode controls behavior) ──
  function loadGA() {
    if (gaLoaded) return;
    gaLoaded = true;

    const gaScript = document.createElement('script');
    gaScript.async = true;
    gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=G-K5N68SRS99';
    document.head.appendChild(gaScript);

    gtag('js', new Date());
    gtag('config', 'G-K5N68SRS99', { send_page_view: true });
  }

  /* Third-party tags are the heaviest scripts on the page (gtag.js alone is ~90kB
   * of parse+execute) and none of them need to run before first paint. Nothing is
   * lost by waiting: gtag/fbq commands issued earlier sit in their queues and
   * replay once the library arrives. Run at first idle, or sooner if the visitor
   * interacts — whichever comes first — so tags never compete with the LCP image. */
  function runWhenIdle(fn: () => void) {
    let done = false;
    const events = ['pointerdown', 'keydown', 'touchstart', 'scroll'];
    const run = () => {
      if (done) return;
      done = true;
      events.forEach((e) => window.removeEventListener(e, run));
      fn();
    };
    events.forEach((e) => window.addEventListener(e, run, { passive: true }));
    if ('requestIdleCallback' in window) {
      (window as any).requestIdleCallback(run, { timeout: 4000 });
    } else {
      window.setTimeout(run, 2500);
    }
  }

  // ── Load Meta Pixel (only after consent granted) ──
  function loadMetaPixel() {
    if (metaPixelLoaded) return;
    metaPixelLoaded = true;

    !function(f: any,b: any,e: any,v: any,n?: any,t?: any,s?: any)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window, document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    window.fbq('init', '1109649517577215');
    window.fbq('track', 'PageView');
    // The pixel is deferred, so it can init after the thank-you page has rendered.
    // This is the single place the Meta lead is sent; loadMetaPixel() is idempotent,
    // so it fires exactly once whether we got here via idle load or via consent.
    if (window.location.pathname === '/dakujeme') {
      window.fbq('track', 'Lead', { content_name: 'contact_form_submission' });
    }
  }

  // ── Load Vercel Analytics (only after consent granted) ──
  function loadVercelAnalytics() {
    import('@vercel/analytics').then(({ inject }) => {
      inject();
    });
  }

  // ── Step 3: Grant consent (called on SAME page, before any navigation) ──
  function grantConsent() {
    gtag('consent', 'update', {
      'ad_storage': 'granted',
      'ad_user_data': 'granted',
      'ad_personalization': 'granted',
      'analytics_storage': 'granted',
    });

    // Load Meta Pixel and Vercel Analytics now that consent is granted
    loadMetaPixel();
    loadVercelAnalytics();
  }

  // ── Deny/revoke consent ──
  function denyConsent() {
    gtag('consent', 'update', {
      'ad_storage': 'denied',
      'ad_user_data': 'denied',
      'ad_personalization': 'denied',
      'analytics_storage': 'denied',
    });
  }

  /** Queue the GA conversion if the user landed on /dakujeme.
   *  Safe to call before gtag.js loads — commands replay from dataLayer.
   *  The matching Meta lead is sent from loadMetaPixel(). */
  function trackThankYouConversion() {
    if (window.location.pathname === '/dakujeme') {
      gtag('event', 'generate_lead', { event_category: 'contact', event_label: 'form_submission' });
    }
  }

  /** Track page views on Astro client-side navigation */
  function trackPageView() {
    gtag('event', 'page_view', {
      page_path: window.location.pathname,
      page_title: document.title,
    });
    window.fbq?.('track', 'PageView');
  }

  /** Track key user actions across all pages */
  function bindEventTracking() {
    if (eventsbound) return;
    eventsbound = true;

    // Use event delegation on document so it works on every page without re-binding
    document.addEventListener('click', (e) => {
      const target = (e.target as HTMLElement).closest('a, button') as HTMLElement | null;
      if (!target) return;

      const href = target.getAttribute('href') || '';

      // Phone click
      if (href.startsWith('tel:')) {
        gtag('event', 'contact_phone', { method: 'phone', link_url: href });
        window.fbq?.('track', 'Contact', { content_name: 'phone' });
        return;
      }

      // Email click
      if (href.startsWith('mailto:')) {
        gtag('event', 'contact_email', { method: 'email', link_url: href });
        window.fbq?.('track', 'Contact', { content_name: 'email' });
        return;
      }

      // CTA buttons (nav CTA, hero CTA)
      if (target.classList.contains('nav-cta-btn') || target.classList.contains('hero-glow-btn')) {
        gtag('event', 'cta_click', { link_text: target.textContent?.trim(), link_url: href });
        window.fbq?.('track', 'Lead', { content_name: target.textContent?.trim() });
        return;
      }

      // Service/portfolio links
      if (href.startsWith('/prace')) {
        gtag('event', 'view_portfolio', { link_url: href, link_text: target.textContent?.trim() });
        window.fbq?.('track', 'ViewContent', { content_name: href });
        return;
      }
    });

    // Contact form submission
    const form = document.getElementById('contact-form');
    form?.addEventListener('submit', () => {
      gtag('event', 'form_submit', { form_name: 'contact' });
      window.fbq?.('track', 'Lead', { content_name: 'contact_form' });
    });
  }

  function initConsent() {
    const banner = document.getElementById('cookie-consent');
    const stored = localStorage.getItem('cookie-consent');

    // Always load GA (consent mode controls what it does) — off the critical path
    runWhenIdle(loadGA);
    // Always bind event tracking (gtag queues events; consent mode controls storage)
    bindEventTracking();

    if (stored === 'accepted') {
      // Consent already granted — load Meta Pixel & Vercel Analytics, also deferred.
      // The conversion event is queued immediately so it survives a fast bounce.
      trackThankYouConversion();
      runWhenIdle(() => {
        loadMetaPixel();
        loadVercelAnalytics();
      });
      return;
    }

    if (stored === 'declined') return;

    // No stored preference — show banner
    banner?.removeAttribute('hidden');

    document.getElementById('cookie-accept')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'accepted');
      banner?.setAttribute('hidden', '');
      // Update consent on THIS page before any navigation
      grantConsent();
      trackThankYouConversion();
    });

    document.getElementById('cookie-decline')?.addEventListener('click', () => {
      localStorage.setItem('cookie-consent', 'declined');
      banner?.setAttribute('hidden', '');
      denyConsent();
    });
  }

  // Run on initial load
  initConsent();

  // On Astro client-side navigation: track new page view + re-check consent
  document.addEventListener('astro:after-swap', () => {
    initConsent();
    trackPageView();
  });
</script>
