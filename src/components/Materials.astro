---
const materials = [
  {
    title: 'Nerez',
    text: 'Odolný proti korózii a nenáročný na údržbu — ideálny do exteriéru aj do vlhkých priestorov.',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>',
  },
  {
    title: 'Oceľ',
    text: 'Konštrukčná pevnosť pre nosné prvky. Vhodná na schody, brány aj ploty.',
    icon: '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="3" y1="12" x2="21" y2="12"></line><line x1="12" y1="3" x2="12" y2="21"></line>',
  },
  {
    title: 'Hliník',
    text: 'Ľahký a stabilný — vhodný pre ploty, brány a exteriérové prvky bez nároku na údržbu.',
    icon: '<path d="M20.24 12.24a6 6 0 00-8.49-8.49L5 10.5V19h8.5z"></path><line x1="16" y1="8" x2="2" y2="22"></line><line x1="17.5" y1="15" x2="9" y2="15"></line>',
  },
];
---

<section class="materials section-dark section-tinted" id="materials">
  <div class="container">
    <div class="materials-header reveal">
      <p class="label-bold">Materiály</p>
      <h2 class="headline-lg">Nerez. Oceľ. Hliník.</h2>
      <p class="materials-subtitle">Materiál vždy prispôsobíme tomu, kde bude výrobok slúžiť a čo musí zvládnuť.</p>
    </div>
    <div class="materials-grid">
      {materials.map((m) => (
        <div class="material-card reveal">
          <div class="material-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={m.icon}></svg>
          </div>
          <h3>{m.title}</h3>
          <p>{m.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
