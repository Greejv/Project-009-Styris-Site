---
import { Image } from 'astro:assets';
import logo from '../assets/logo-trim.png';

const LOGO_H = 22;
const LOGO_W = Math.round((LOGO_H * logo.width) / logo.height);

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
/** Build a link that scrolls smoothly on the homepage and navigates otherwise. */
const homeAnchor = (hash: string) => (isHome ? `#${hash}` : `/#${hash}`);

const links = [
  { label: 'Domov', href: isHome ? '#hero' : '/', section: 'hero' },
  { label: 'Realizácie', href: homeAnchor('gallery'), section: 'gallery' },
  { label: 'Naše práce', href: '/prace', section: 'prace', isPage: true },
  { label: 'Proces', href: homeAnchor('process'), section: 'process' },
  { label: 'Prečo my', href: homeAnchor('quality'), section: 'quality' },
  { label: 'Kontakt', href: '/kontakt', section: 'contact', isPage: true },
];

const isPraceActive = pathname === '/prace' || pathname.startsWith('/prace/');
---

<header>
<nav class="nav" id="nav" data-page={isHome ? 'home' : 'other'} aria-label="Hlavná navigácia">
  <div class="container nav-inner">
    <a href="/" class="nav-logo logo-plate" aria-label="Styris — domov">
      <Image
        src={logo}
        alt="Styris"
        height={LOGO_H}
        width={LOGO_W}
        densities={[1, 2, 3]}
        loading="eager"
        format="png"
      />
    </a>
    <div class="nav-links" id="nav-links">
      {links.map((l) => (
        <a
          href={l.href}
          data-nav-link={isHome && !l.isPage ? '' : undefined}
          class:list={[l.isPage && isPraceActive && 'is-active']}
        >
          {l.label}
        </a>
      ))}
    </div>
    <div class="nav-cta">
      <a href="/kontakt" class="btn btn-primary nav-cta-btn">
        <span>Cenová ponuka</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
    <button class="mobile-toggle" id="mobile-toggle" aria-label="Menu" aria-expanded="false" aria-controls="nav-links">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>
</header>
