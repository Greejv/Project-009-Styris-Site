---
const stats = [
  {
    number: '5+',
    label: 'rokov skúseností',
    icon: '<circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>',
  },
  {
    number: '100+',
    label: 'realizácií',
    icon: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>',
  },
  {
    number: '100%',
    label: 'vlastná výroba',
    icon: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path>',
  },
  {
    number: 'Každý kus',
    label: 'na mieru, ručne',
    icon: '<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"></path>',
  },
];
---

<section class="social-proof section-dark">
  <div class="container">
    <div class="proof-grid">
      {stats.map((s, i) => (
        <>
          <div class="proof-item reveal">
            <div class="proof-icon"><svg viewBox="0 0 24 24" aria-hidden="true" set:html={s.icon}></svg></div>
            <span class="proof-number">{s.number}</span>
            <span class="proof-label">{s.label}</span>
          </div>
          {i < stats.length - 1 && <div class="proof-divider"></div>}
        </>
      ))}
    </div>
  </div>
</section>
