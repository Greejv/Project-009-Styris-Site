---
import { Image } from 'astro:assets';
import imgLeft from '../assets/products/biele_schody_1.webp';
import imgRight from '../assets/products/Biele_Zabradlie_1.webp';
---

<section class="hero" id="hero">
  <div class="hero-split">
    <div class="hero-split-img">
      <Image
        src={imgLeft}
        alt="Ručne vyrobené interiérové kovové schodisko na mieru"
        width={1280}
        height={Math.round((1280 * imgLeft.height) / imgLeft.width)}
        widths={[640, 960, 1280]}
        sizes="(max-width: 900px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
        style="object-position: center 30%;"
      />
    </div>
    <div class="hero-split-img">
      <Image
        src={imgRight}
        alt="Elegantné kovové zábradlie od Styris"
        width={1280}
        height={Math.round((1280 * imgRight.height) / imgRight.width)}
        widths={[640, 960, 1280]}
        sizes="(max-width: 900px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
        style="object-position: center 40%;"
      />
    </div>
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-fade"></div>
  <div class="hero-glass">
    <h1 class="hero-title">
      <span class="line-bold">Kovové brány, schody a zábradlia</span>
      <span class="line-light">na mieru podľa vašich predstáv.</span>
    </h1>
    <p class="hero-desc">Ručná výroba pre rodinné domy v Košickom kraji. Žiadne katalógové riešenia — len vaša vízia v kove.</p>
    <div class="hero-cta-row">
      <a href="#contact" class="hero-glow-btn">
        <span style="color: #ffffff">Chcem cenovú ponuku zadarmo</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12" style="stroke: rgb(255, 255, 255)"></line><polyline points="12 5 19 12 12 19" style="stroke: rgb(255, 255, 255)"></polyline></svg>
      </a>
      <a href="/prace" class="hero-quiet-btn">
        <span>Pozrieť naše práce</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
      </a>
    </div>
    <p class="hero-trust">✓ Bez záväzkov &nbsp;&nbsp; ✓ Odpoveď do 24 hodín &nbsp;&nbsp; ✓ Košický kraj</p>
  </div>
</section>
