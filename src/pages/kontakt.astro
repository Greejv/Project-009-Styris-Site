---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = 'Kontakt — napíšte nám o vašom projekte | Styris';
const description =
  'Napíšte nám o vašom projekte na mieru — schody, brány, zábradlia, pergoly. Ozveme sa do 48 hodín s návrhom riešenia a orientačnou cenou.';
---

<Layout title={title} description={description}>
  <Nav />
  <main class="contact-main">
    <Contact />
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/main.ts';
</script>
