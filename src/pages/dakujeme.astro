---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Ďakujeme za správu — Styris';
const description = 'Vaša správa bola úspešne odoslaná. Ozveme sa vám do 48 hodín.';
---

<Layout title={title} description={description}>
  <Nav />
  <main class="thankyou-main">
    <section class="thankyou-hero">
      <div class="container">
        <div class="thankyou-card">
          <div class="ty-send" aria-hidden="true">
            <svg class="ty-send-svg" viewBox="0 0 220 120" fill="none" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="tyTrailGrad" x1="0" y1="1" x2="1" y2="0">
                  <stop offset="0%" stop-color="#e5ad20" stop-opacity="0"></stop>
                  <stop offset="40%" stop-color="#e5ad20" stop-opacity="0.5"></stop>
                  <stop offset="100%" stop-color="#e5ad20" stop-opacity="1"></stop>
                </linearGradient>
              </defs>
              <path class="ty-trail" pathLength="100" d="M 14 100 C 58 96, 76 40, 116 54 C 152 67, 176 46, 206 16"></path>
              <g class="ty-plane"><path d="M -10 -7 L 12 0 L -10 7 L -5.5 0 Z"></path></g>
            </svg>
            <div class="ty-badge">
              <span class="ty-badge-ring"></span>
              <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                <polyline class="ty-check" pathLength="100" points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
          </div>
          <h1 class="thankyou-title">Ďakujeme za vašu správu!</h1>
          <p class="thankyou-text">Vaša správa bola úspešne odoslaná. Ozveme sa vám <strong>do 48 hodín</strong> s návrhom riešenia a orientačnou cenou.</p>

          <div class="thankyou-next">
            <h2>Čo sa stane ďalej?</h2>
            <ol class="thankyou-steps">
              <li>
                <span class="thankyou-step-num">1</span>
                <div>
                  <strong>Preštudujeme váš dopyt</strong>
                  <p>Prečítame si vašu správu a pripravíme predbežnú odpoveď.</p>
                </div>
              </li>
              <li>
                <span class="thankyou-step-num">2</span>
                <div>
                  <strong>Ozveme sa vám</strong>
                  <p>Kontaktujeme vás e-mailom alebo telefonicky pre upresnenie detailov.</p>
                </div>
              </li>
              <li>
                <span class="thankyou-step-num">3</span>
                <div>
                  <strong>Pripravíme ponuku</strong>
                  <p>Pošleme vám návrh riešenia a orientačnú cenu. 3D vizualizáciu pripravíme až po odsúhlasení ceny.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="thankyou-contact-section">
            <p class="label-bold thankyou-contact-eyebrow">Kontakt</p>
            <h2 class="thankyou-contact-heading">Potrebujete nás skôr?</h2>
            <p class="thankyou-contact-desc">Kým sa ozveme, pokojne nám zavolajte alebo napíšte priamo.</p>
            <div class="thankyou-contact-items">
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                </div>
                <a href="tel:+421940896866">+421 940 896 866</a>
              </div>
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <a href="mailto:info@styris.sk">info@styris.sk</a>
              </div>
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                </div>
                <a href="https://www.instagram.com/styris.sk/" target="_blank" rel="noopener">@styris.sk</a>
              </div>
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span>Košice · celé Slovensko</span>
              </div>
            </div>
          </div>

          <div class="thankyou-actions">
            <a href="/" class="btn btn-primary">Späť na hlavnú stránku</a>
            <a href="/prace" class="btn btn-outline">Pozrite si naše práce</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/main.ts';
</script>
