---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const title = 'Ďakujeme za správu — Styris';
const description = 'Vaša správa bola úspešne odoslaná. Ozveme sa vám do 24 hodín.';
---

<Layout title={title} description={description}>
  <Nav />
  <main class="thankyou-main">
    <section class="thankyou-hero">
      <div class="container">
        <div class="thankyou-card">
          <div class="thankyou-icon">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </div>
          <h1 class="thankyou-title">Ďakujeme za vašu správu!</h1>
          <p class="thankyou-text">Vaša správa bola úspešne odoslaná. Ozveme sa vám <strong>do 24 hodín</strong> — zvyčajne však oveľa skôr.</p>

          <div class="thankyou-next">
            <h2>Čo sa stane ďalej?</h2>
            <ol class="thankyou-steps">
              <li>
                <span class="thankyou-step-num">1</span>
                <div>
                  <strong>Preštudujeme váš dopyt</strong>
                  <p>Prečítame si vašu správu a pripravíme predbežnú odpoveď.</p>
                </div>
              </li>
              <li>
                <span class="thankyou-step-num">2</span>
                <div>
                  <strong>Ozveme sa vám</strong>
                  <p>Kontaktujeme vás e-mailom alebo telefonicky pre upresnenie detailov.</p>
                </div>
              </li>
              <li>
                <span class="thankyou-step-num">3</span>
                <div>
                  <strong>Pripravíme ponuku</strong>
                  <p>Vytvoríme pre vás cenovú ponuku s 3D vizualizáciou zadarmo.</p>
                </div>
              </li>
            </ol>
          </div>

          <div class="thankyou-contact-section">
            <p class="label-bold thankyou-contact-eyebrow">Kontakt</p>
            <h2 class="thankyou-contact-heading">Napíšte nám o&nbsp;vašom projekte</h2>
            <p class="thankyou-contact-desc">Radi vám pomôžeme s realizáciou vášho projektu. Kontaktujte nás pre bezplatnú konzultáciu.</p>
            <div class="thankyou-contact-items">
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                </div>
                <a href="tel:+421940498866">+421 940 498 866</a>
              </div>
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <a href="mailto:info@styris.sk">info@styris.sk</a>
              </div>
              <div class="thankyou-contact-item">
                <div class="thankyou-contact-icon">
                  <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <span>Košická 18, 044 14 Čaňa</span>
              </div>
            </div>
          </div>

          <div class="thankyou-actions">
            <a href="/" class="btn btn-primary">Späť na hlavnú stránku</a>
            <a href="/prace" class="btn btn-outline">Pozrite si naše práce</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/main.ts';
</script>
