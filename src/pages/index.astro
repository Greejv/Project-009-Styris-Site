---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import Services from '../components/Services.astro';
import Process from '../components/Process.astro';
import Quality from '../components/Quality.astro';
import Materials from '../components/Materials.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <SocialProof />
    <Services />
    <Process />
    <Quality />
    <Materials />
    <section class="contact section-dark" id="contact">
      <div class="container">
        <div class="contact-inner">
          <div class="reveal">
            <p class="label-bold">Kontakt</p>
            <h2 class="headline-lg">Napíšte nám o&nbsp;vašom projekte</h2>
            <p class="contact-desc">Napíšte nám, čo potrebujete. Ozveme sa do 48 hodín s návrhom riešenia a orientačnou cenou.</p>
            <div class="contact-info">
              <div class="contact-info-item">
                <div class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.362 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0122 16.92z"></path></svg>
                </div>
                <a href="tel:+421940896866"><span>+421 940 896 866</span></a>
              </div>
              <div class="contact-info-item">
                <div class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                </div>
                <a href="mailto:info@styris.sk"><span>info@styris.sk</span></a>
              </div>
              <div class="contact-info-item">
                <div class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                </div>
                <a href="https://www.instagram.com/styris.sk/" target="_blank" rel="noopener"><span>@styris.sk</span></a>
              </div>
              <div class="contact-info-item">
                <div class="icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.8" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <span>Košice · celé Slovensko</span>
              </div>
            </div>
          </div>

          <div class="work-cta-bottom reveal">
            <h3>Máte na mysli projekt?</h3>
            <p>Nezáväzná cenová ponuka zdarma. Napíšte nám, čo potrebujete, a ozveme sa do 48 hodín s návrhom riešenia a orientačnou cenou.</p>
            <a href="/kontakt" class="btn btn-primary work-contact-btn">
              Napísať nám o projekte
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import '../scripts/main.ts';
</script>
